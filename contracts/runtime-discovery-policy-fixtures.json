{
  "cases": [
    {
      "name": "full_auto_ws_pull",
      "manifest": {
        "base_urls": {
          "runtime": "https://runtime.example.test:8443"
        },
        "runtime": {
          "enabled": true,
          "mtls_required": true,
          "transports": [
            "websocket",
            "long_poll"
          ],
          "default_transport": "auto",
          "transport_policy": {
            "version": 1,
            "heartbeat_interval_seconds": 20,
            "session_stale_after_seconds": 45,
            "retry_minimum_ms": 250,
            "retry_maximum_ms": 15000,
            "websocket_probe_interval_ms": 15000,
            "websocket_probe_timeout_ms": 10000
          }
        }
      },
      "expected": {
        "allowed": [
          "ws",
          "pull"
        ],
        "default": "auto",
        "heartbeat_interval_ms": 20000,
        "session_stale_after_ms": 45000,
        "retry_minimum_ms": 250,
        "retry_maximum_ms": 15000,
        "websocket_probe_interval_ms": 15000,
        "websocket_probe_timeout_ms": 10000
      }
    },
