{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "openlinker-runtime",
  "scope": "core-runtime",
  "version": "v2",
  "runtime_contract_id": "openlinker.runtime.v2",
  "protocol_version": 2,
  "wire_format": "application/json",
  "required_features": [
    "lease_fence",
    "assignment_confirm",
    "renew",
    "resume",
    "event_ack",
    "result_ack",
    "cancel",
    "persistent_spool"
  ],
  "limits": {
    "max_non_artifact_message_bytes": 4194304,
    "offer_ttl_seconds": 30,
    "lease_ttl_seconds": 60,
    "lease_renew_interval_seconds": 20,
    "hello_timeout_seconds": 5,
    "max_pull_wait_seconds": 30
  },
  "websocket": {
    "path": "/api/v1/agent-runtime/ws",
    "auth": "agent_principal_and_node_device",
    "envelope_schema": {
      "$ref": "#/$defs/RuntimeMessage"
    },
    "close_codes": {
      "4401": "AUTHENTICATION_FAILED",
      "4406": "RUNTIME_CLIENT_UPGRADE_REQUIRED",
      "4409": "RUNTIME_SESSION_CONFLICT",
      "4412": "RUNTIME_REQUIRED_FEATURE_MISSING"
    },
    "messages": [
      {
        "type": "runtime.hello",
        "direction": "node_to_core",
        "expects_reply": true,
        "schema": {
          "$ref": "#/$defs/RuntimeHelloMessage"
        }
      },
      {
        "type": "runtime.ready",
        "direction": "core_to_node",
        "reply_to_required": true,
        "schema": {
          "$ref": "#/$defs/RuntimeReadyMessage"
        }
      },
      {
        "type": "run.assigned",
        "direction": "core_to_node",
        "expects_reply": true,
        "schema": {
          "$ref": "#/$defs/RunAssignedMessage"
        }
      },
      {
        "type": "run.assignment.ack",
        "direction": "node_to_core",
        "expects_reply": true,
        "reply_to_required": true,
        "schema": {
          "$ref": "#/$defs/RunAssignmentAckMessage"
        }
      },
      {
        "type": "run.assignment.confirmed",
        "direction": "core_to_node",
        "reply_to_required": true,
        "schema": {
          "$ref": "#/$defs/RunAssignmentConfirmedMessage"
        }
      },
      {
        "type": "run.assignment.reject",
        "direction": "node_to_core",
        "expects_reply": true,
        "reply_to_required": true,
        "schema": {
          "$ref": "#/$defs/RunAssignmentRejectMessage"
        }
      },
      {
        "type": "run.assignment.rejected",
        "direction": "core_to_node",
        "reply_to_required": true,
        "schema": {
          "$ref": "#/$defs/RunAssignmentRejectedMessage"
        }
      },
      {
        "type": "run.lease.renew",
        "direction": "node_to_core",
        "expects_reply": true,
        "schema": {
          "$ref": "#/$defs/RunLeaseRenewMessage"
        }
      },
      {
        "type": "run.lease.renewed",
        "direction": "core_to_node",
        "reply_to_required": true,
        "schema": {
          "$ref": "#/$defs/RunLeaseRenewedMessage"
        }
      },
      {
        "type": "run.event",
        "direction": "node_to_core",
        "expects_reply": true,
        "schema": {
          "$ref": "#/$defs/RunEventMessage"
        }
      },
      {
        "type": "run.event.ack",
        "direction": "core_to_node",
        "reply_to_required": true,
        "schema": {
          "$ref": "#/$defs/RunEventAckMessage"
        }
      },
      {
        "type": "run.result",
        "direction": "node_to_core",
        "expects_reply": true,
        "schema": {
          "$ref": "#/$defs/RunResultMessage"
        }
      },
      {
        "type": "run.result.ack",
        "direction": "core_to_node",
        "reply_to_required": true,
        "schema": {
          "$ref": "#/$defs/RunResultAckMessage"
        }
      },
      {
        "type": "run.cancel",
        "direction": "core_to_node",
        "expects_reply": true,
        "schema": {
          "$ref": "#/$defs/RunCancelMessage"
        }
      },
      {
        "type": "run.cancel.ack",
        "direction": "node_to_core",
        "reply_to_required": true,
        "schema": {
          "$ref": "#/$defs/RunCancelAckMessage"
        }
      },
      {
        "type": "runtime.resume",
        "direction": "node_to_core",
        "expects_reply": true,
        "schema": {
          "$ref": "#/$defs/RuntimeResumeMessage"
        }
      },
      {
        "type": "run.resume.accepted",
        "direction": "core_to_node",
        "reply_to_required": true,
        "schema": {
          "$ref": "#/$defs/RunResumeAcceptedMessage"
        }
      },
      {
        "type": "run.lease.revoked",
        "direction": "core_to_node",
        "schema": {
          "$ref": "#/$defs/RunLeaseRevokedMessage"
        }
      },
      {
        "type": "runtime.drain",
        "direction": "bidirectional",
        "schema": {
          "$ref": "#/$defs/RuntimeDrainMessage"
        }
      },
      {
        "type": "runtime.error",
        "direction": "core_to_node",
        "reply_to_required": true,
        "schema": {
          "$ref": "#/$defs/RuntimeErrorMessage"
        }
      }
    ]
  },
  "endpoints": [
    {
      "client_method": "createRuntimeSession",
      "http_method": "POST",
      "path": "/api/v1/agent-runtime/sessions",
      "request_body_schema": {
        "$ref": "#/$defs/RuntimeHelloPayload"
      },
      "success_response_schema": {
        "$ref": "#/$defs/RuntimeReadyPayload"
      },
      "error_response_schema": {
        "$ref": "#/$defs/RuntimeError"
      }
    },
    {
      "client_method": "heartbeatRuntimeSession",
      "http_method": "POST",
      "path": "/api/v1/agent-runtime/sessions/{id}/heartbeat",
      "required_headers": [
        "OpenLinker-Runtime-Attachment"
      ],
      "request_body_schema": {
        "$ref": "#/$defs/RuntimeHelloPayload"
      },
      "success_response_schema": {
        "$ref": "#/$defs/RuntimeReadyPayload"
      },
      "error_response_schema": {
        "$ref": "#/$defs/RuntimeError"
      }
    },
    {
      "client_method": "closeRuntimeSession",
      "http_method": "POST",
      "path": "/api/v1/agent-runtime/sessions/{id}/close",
      "required_headers": [
        "OpenLinker-Runtime-Attachment"
      ],
      "request_body_schema": {
        "$ref": "#/$defs/RuntimeSessionCloseRequest"
      },
      "empty_response_status": 204,
      "error_response_schema": {
        "$ref": "#/$defs/RuntimeError"
      }
    },
    {
      "client_method": "claimRuntimeRun",
      "http_method": "POST",
      "path": "/api/v1/agent-runtime/runs/claim",
      "required_headers": [
        "OpenLinker-Runtime-Attachment"
      ],
      "query": {
        "wait": {
          "type": "integer",
          "minimum": 0,
          "maximum": 30
        }
      },
      "request_body_schema": {
        "$ref": "#/$defs/RuntimeClaimRequest"
      },
      "success_response_schema": {
        "$ref": "#/$defs/RunAssignedPayload"
      },
      "empty_response_status": 204,
      "error_response_schema": {
        "$ref": "#/$defs/RuntimeError"
      }
    },
    {
      "client_method": "ackRuntimeAssignment",
      "http_method": "POST",
      "path": "/api/v1/agent-runtime/runs/{id}/assignment-ack",
      "required_headers": [
        "OpenLinker-Runtime-Attachment"
      ],
      "request_body_schema": {
        "$ref": "#/$defs/RunAssignmentAckPayload"
      },
      "success_response_schema": {
        "$ref": "#/$defs/RunAssignmentConfirmedPayload"
      },
      "error_response_schema": {
        "$ref": "#/$defs/RuntimeError"
      }
    },
    {
      "client_method": "rejectRuntimeAssignment",
      "http_method": "POST",
      "path": "/api/v1/agent-runtime/runs/{id}/assignment-reject",
      "required_headers": [
        "OpenLinker-Runtime-Attachment"
      ],
      "request_body_schema": {
        "$ref": "#/$defs/RunAssignmentRejectPayload"
      },
      "success_response_schema": {
        "$ref": "#/$defs/RunAssignmentRejectedPayload"
      },
      "error_response_schema": {
        "$ref": "#/$defs/RuntimeError"
      }
    },
    {
      "client_method": "renewRuntimeLease",
      "http_method": "POST",
      "path": "/api/v1/agent-runtime/runs/{id}/lease-renew",
      "required_headers": [
        "OpenLinker-Runtime-Attachment"
      ],
      "request_body_schema": {
        "$ref": "#/$defs/RunLeaseRenewPayload"
      },
      "success_response_schema": {
        "$ref": "#/$defs/RunLeaseRenewedPayload"
      },
      "error_response_schema": {
        "$ref": "#/$defs/RuntimeError"
      }
    },
    {
      "client_method": "sendRuntimeEvent",
      "http_method": "POST",
      "path": "/api/v1/agent-runtime/runs/{id}/events",
      "required_headers": [
        "OpenLinker-Runtime-Attachment"
      ],
      "request_body_schema": {
        "$ref": "#/$defs/RunEventPayload"
      },
      "success_response_schema": {
        "$ref": "#/$defs/RunEventAckPayload"
      },
      "error_response_schema": {
        "$ref": "#/$defs/RuntimeError"
      }
    },
    {
      "client_method": "completeRuntimeRun",
      "http_method": "POST",
      "path": "/api/v1/agent-runtime/runs/{id}/result",
      "required_headers": [
        "OpenLinker-Runtime-Attachment"
      ],
      "request_body_schema": {
        "$ref": "#/$defs/RunResultPayload"
      },
      "success_response_schema": {
        "$ref": "#/$defs/RunResultAckPayload"
      },
      "error_response_schema": {
        "$ref": "#/$defs/RuntimeError"
      }
    },
    {
      "client_method": "resumeRuntimeRuns",
      "http_method": "POST",
      "path": "/api/v1/agent-runtime/runs/resume",
      "required_headers": [
        "OpenLinker-Runtime-Attachment"
      ],
      "request_body_schema": {
        "$ref": "#/$defs/RuntimeResumePayload"
      },
      "success_response_schema": {
        "$ref": "#/$defs/RuntimeResumeResponse"
      },
      "error_response_schema": {
        "$ref": "#/$defs/RuntimeError"
      }
    },
    {
      "client_method": "ackRuntimeCancel",
      "http_method": "POST",
      "path": "/api/v1/agent-runtime/runs/{id}/cancel-ack",
      "required_headers": [
        "OpenLinker-Runtime-Attachment"
      ],
      "request_body_schema": {
        "$ref": "#/$defs/RunCancelAckPayload"
      },
      "success_response_schema": {
        "$ref": "#/$defs/RunCancellationState"
      },
      "error_response_schema": {
        "$ref": "#/$defs/RuntimeError"
      }
    },
    {
      "client_method": "pollRuntimeCommands",
      "http_method": "GET",
      "path": "/api/v1/agent-runtime/commands",
      "required_headers": [
        "OpenLinker-Runtime-Attachment"
      ],
      "query": {
        "runtime_session_id": {
          "type": "string",
          "format": "uuid",
          "required": true
        },
        "wait": {
          "type": "integer",
          "minimum": 0,
          "maximum": 30
        }
      },
      "success_response_schema": {
        "$ref": "#/$defs/RuntimeCommandsResponse"
      },
      "error_response_schema": {
        "$ref": "#/$defs/RuntimeError"
      }
    },
    {
      "client_method": "callAgent",
      "http_method": "POST",
      "path": "/api/v1/agent-runtime/call-agent",
      "required_headers": [
        "Idempotency-Key",
        "OpenLinker-Invocation-Context",
        "OpenLinker-Invocation-Proof"
      ],
      "request_body_schema": {
        "$ref": "#/$defs/CallAgentRequest"
      },
      "success_response_schema": {
        "$ref": "#/$defs/RunSummary"
      },
      "error_response_schema": {
        "$ref": "#/$defs/RuntimeError"
      }
    }
  ],
  "stable_error_codes": [
    "BAD_REQUEST",
    "UNAUTHORIZED",
    "FORBIDDEN",
    "PERMISSION_DENIED",
    "NOT_FOUND",
    "CONFLICT",
    "VALIDATION_FAILED",
    "RATE_LIMITED",
    "INTERNAL_ERROR",
    "SERVICE_UNAVAILABLE",
    "IDEMPOTENCY_KEY_REUSED",
    "RUN_ALREADY_TERMINAL",
    "STALE_LEASE",
    "LEASE_EXPIRED",
    "LEASE_IDENTITY_MISMATCH",
    "RESULT_ID_CONFLICT",
    "EVENT_ID_CONFLICT",
    "NODE_AT_CAPACITY",
    "RUNTIME_CLIENT_UPGRADE_REQUIRED",
    "RUNTIME_REQUIRED_FEATURE_MISSING",
    "RUN_CANCEL_REQUESTED",
    "RUN_CANCEL_UNCONFIRMED",
    "RUNTIME_RETRY_EXHAUSTED",
    "RUNTIME_DISPATCH_TIMEOUT",
    "RUN_DEADLINE_EXCEEDED",
    "EVENTS_MISSING",
    "REPLAY_INPUT_UNAVAILABLE",
    "ENDPOINT_RESULT_UNKNOWN",
    "RUNTIME_SESSION_CONFLICT",
    "RUNTIME_SPOOL_CORRUPT"
  ],
  "$defs": {
    "UUID": {
      "type": "string",
      "format": "uuid"
    },
    "Timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "NonNegativeInteger": {
      "type": "integer",
      "minimum": 0
    },
    "PositiveInteger": {
      "type": "integer",
      "minimum": 1
    },
    "RunStatus": {
      "type": "string",
      "enum": [
        "running",
        "success",
        "failed",
        "timeout",
        "canceled"
      ]
    },
    "DispatchState": {
      "type": "string",
      "enum": [
        "pending",
        "offered",
        "executing",
        "retry_wait",
        "terminal",
        "dead_letter"
      ]
    },
    "CancelState": {
      "type": "string",
      "enum": [
        "requested",
        "delivered",
        "stopping",
        "stopped",
        "unsupported",
        "failed",
        "unconfirmed"
      ]
    },
    "ResumeDecision": {
      "type": "string",
      "enum": [
        "continue_execution",
        "upload_spool_only",
        "result_already_acked",
        "lease_revoked"
      ]
    },
    "AttemptIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "attempt_id",
        "lease_id",
        "fencing_token",
        "node_id",
        "agent_id",
        "worker_id",
        "runtime_session_id"
      ],
      "properties": {
        "run_id": {
          "$ref": "#/$defs/UUID"
        },
        "attempt_id": {
          "$ref": "#/$defs/UUID"
        },
        "lease_id": {
          "$ref": "#/$defs/UUID"
        },
        "fencing_token": {
          "type": "integer",
          "minimum": 1
        },
        "node_id": {
          "$ref": "#/$defs/UUID"
        },
        "agent_id": {
          "$ref": "#/$defs/UUID"
        },
        "worker_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "runtime_session_id": {
          "$ref": "#/$defs/UUID"
        }
      }
    },
    "EventRange": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start",
        "end"
      ],
      "properties": {
        "start": {
          "type": "integer",
          "minimum": 1
        },
        "end": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "RuntimeErrorBody": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "BAD_REQUEST",
            "UNAUTHORIZED",
            "FORBIDDEN",
            "PERMISSION_DENIED",
            "NOT_FOUND",
            "CONFLICT",
            "VALIDATION_FAILED",
            "RATE_LIMITED",
            "INTERNAL_ERROR",
            "SERVICE_UNAVAILABLE",
            "IDEMPOTENCY_KEY_REUSED",
            "RUN_ALREADY_TERMINAL",
            "STALE_LEASE",
            "LEASE_EXPIRED",
            "LEASE_IDENTITY_MISMATCH",
            "RESULT_ID_CONFLICT",
            "EVENT_ID_CONFLICT",
            "NODE_AT_CAPACITY",
            "RUNTIME_CLIENT_UPGRADE_REQUIRED",
            "RUNTIME_REQUIRED_FEATURE_MISSING",
            "RUN_CANCEL_REQUESTED",
            "RUN_CANCEL_UNCONFIRMED",
            "RUNTIME_RETRY_EXHAUSTED",
            "RUNTIME_DISPATCH_TIMEOUT",
            "RUN_DEADLINE_EXCEEDED",
            "EVENTS_MISSING",
            "REPLAY_INPUT_UNAVAILABLE",
            "ENDPOINT_RESULT_UNKNOWN",
            "RUNTIME_SESSION_CONFLICT",
            "RUNTIME_SPOOL_CORRUPT"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "retryable": {
          "type": "boolean"
        },
        "missing_event_ranges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EventRange"
          }
        },
        "current_run_status": {
          "$ref": "#/$defs/RunStatus"
        },
        "current_dispatch_state": {
          "$ref": "#/$defs/DispatchState"
        }
      }
    },
    "RuntimeError": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "error"
      ],
      "properties": {
        "error": {
          "$ref": "#/$defs/RuntimeErrorBody"
        }
      }
    },
    "RuntimeEnvelope": {
      "type": "object",
      "required": [
        "protocol_version",
        "runtime_contract_id",
        "message_id",
        "type",
        "sent_at",
        "payload"
      ],
      "properties": {
        "protocol_version": {
          "const": 2
        },
        "runtime_contract_id": {
          "const": "openlinker.runtime.v2"
        },
        "message_id": {
          "$ref": "#/$defs/UUID"
        },
        "reply_to_message_id": {
          "$ref": "#/$defs/UUID"
        },
        "type": {
          "type": "string"
        },
        "sent_at": {
          "$ref": "#/$defs/Timestamp"
        },
        "payload": {
          "type": "object"
        }
      }
    },
    "RuntimeMessage": {
      "oneOf": [
        {
          "$ref": "#/$defs/RuntimeHelloMessage"
        },
        {
          "$ref": "#/$defs/RuntimeReadyMessage"
        },
        {
          "$ref": "#/$defs/RunAssignedMessage"
        },
        {
          "$ref": "#/$defs/RunAssignmentAckMessage"
        },
        {
          "$ref": "#/$defs/RunAssignmentConfirmedMessage"
        },
        {
          "$ref": "#/$defs/RunAssignmentRejectMessage"
        },
        {
          "$ref": "#/$defs/RunAssignmentRejectedMessage"
        },
        {
          "$ref": "#/$defs/RunLeaseRenewMessage"
        },
        {
          "$ref": "#/$defs/RunLeaseRenewedMessage"
        },
        {
          "$ref": "#/$defs/RunEventMessage"
        },
        {
          "$ref": "#/$defs/RunEventAckMessage"
        },
        {
          "$ref": "#/$defs/RunResultMessage"
        },
        {
          "$ref": "#/$defs/RunResultAckMessage"
        },
        {
          "$ref": "#/$defs/RunCancelMessage"
        },
        {
          "$ref": "#/$defs/RunCancelAckMessage"
        },
        {
          "$ref": "#/$defs/RuntimeResumeMessage"
        },
        {
          "$ref": "#/$defs/RunResumeAcceptedMessage"
        },
        {
          "$ref": "#/$defs/RunLeaseRevokedMessage"
        },
        {
          "$ref": "#/$defs/RuntimeDrainMessage"
        },
        {
          "$ref": "#/$defs/RuntimeErrorMessage"
        }
      ]
    },
    "RuntimeHelloPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_id",
        "agent_id",
        "worker_id",
        "runtime_session_id",
        "session_epoch",
        "node_version",
        "capacity",
        "features",
        "contract_digest"
      ],
      "properties": {
        "node_id": {
          "$ref": "#/$defs/UUID"
        },
        "agent_id": {
          "$ref": "#/$defs/UUID"
        },
        "worker_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "runtime_session_id": {
          "$ref": "#/$defs/UUID"
        },
        "session_epoch": {
          "type": "integer",
          "minimum": 1
        },
        "node_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "capacity": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1024
        },
        "features": {
          "type": "array",
          "uniqueItems": true,
          "minItems": 8,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          }
        },
        "contract_digest": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "RuntimeReadyPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "core_instance_id",
        "attachment_id",
        "features",
        "offer_ttl_seconds",
        "lease_ttl_seconds",
        "database_time"
      ],
      "properties": {
        "core_instance_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "attachment_id": {
          "type": "string",
          "format": "uuid"
        },
        "features": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "offer_ttl_seconds": {
          "$ref": "#/$defs/PositiveInteger"
        },
        "lease_ttl_seconds": {
          "$ref": "#/$defs/PositiveInteger"
        },
        "database_time": {
          "$ref": "#/$defs/Timestamp"
        }
      }
    },
    "RuntimeSessionCloseRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_id",
        "agent_id",
        "worker_id",
        "runtime_session_id",
        "session_epoch",
        "status",
        "reason"
      ],
      "properties": {
        "node_id": {
          "$ref": "#/$defs/UUID"
        },
        "agent_id": {
          "$ref": "#/$defs/UUID"
        },
        "worker_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "runtime_session_id": {
          "$ref": "#/$defs/UUID"
        },
        "session_epoch": {
          "$ref": "#/$defs/PositiveInteger"
        },
        "status": {
          "type": "string",
          "enum": [
            "offline",
            "closed"
          ]
